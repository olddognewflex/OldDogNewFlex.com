---
// src/components/blog/BlogCard.astro
import { Calendar, Clock, Tag } from '@lucide/astro';
import type { BlogPost } from '../../lib/blog';
import { getPostUrl, getReadingTime } from '../../lib/blog';
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import FormattedDate from '../FormattedDate.astro';

export interface Props {
  post: BlogPost;
  featured?: boolean;
}

const COLLECTION_LABELS: Record<string, string> = {
  learn: 'Learn',
  share: 'Share',
  journey: 'Journey',
};

const { post, featured = false } = Astro.props;
const postUrl = getPostUrl(post);
const readingTime = post.body ? getReadingTime(post.body) : 'Unknown';
const collectionLabel = COLLECTION_LABELS[post.collection] ?? post.collection;
---

<Card variant={featured ? 'featured' : 'default'}>
  <div class="flex items-center gap-4 text-sm text-subtext0 mb-3">
    <span class="flex items-center gap-1">
      <Calendar size={16} aria-hidden="true" />
      <FormattedDate date={post.data.publishedDate} />
    </span>
    <span class="flex items-center gap-1">
      <Clock size={16} aria-hidden="true" />
      {readingTime}
    </span>
    <Badge variant="collection" size="sm">
      {collectionLabel}
    </Badge>
  </div>
  
  <a href={postUrl} class="group block">
    <h3 class="text-xl font-bold group-hover:text-peach transition-colors mb-2">
      {post.data.title}
    </h3>
    <p class="text-overlay2 mb-4">{post.data.summary}</p>
  </a>
  
  {post.data.tags && post.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {post.data.tags.map((tag) => (
        <Badge variant="tag" size="sm">
          <Tag size={12} aria-hidden="true" />
          {tag}
        </Badge>
      ))}
    </div>
  )}
</Card>
