---
// src/components/blog/BlogCard.astro
import { Calendar, Clock, Tag } from '@lucide/astro';
import type { BlogPost } from '../../lib/blog';
import { getPostUrl, getReadingTime } from '../../lib/blog';

export interface Props {
  post: BlogPost;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const postUrl = getPostUrl(post);
const readingTime = post.body ? getReadingTime(post.body) : 'Unknown';
const cardClass = featured 
  ? "bg-gradient-to-br from-(--catppuccin-flamingo) to-(--catppuccin-mauve) border-2 border-orange-200" 
  : "bg-(--catppuccin-surface2) border border-gray-200 hover:border-orange-300";
---

<article class={`rounded-lg p-6 transition-all duration-200 hover:shadow-lg ${cardClass}`}>
  <div class="flex items-center gap-4 text-sm text-gray-600 mb-3">
    <span class="flex items-center gap-1">
      <Calendar size="4" />
      {post.data.publishedDate.toLocaleDateString('en-US', { 
        year: 'numeric', 
        month: 'short', 
        day: 'numeric' 
      })}
    </span>
    <span class="flex items-center gap-1">
      <Clock size="4" />
      {readingTime}
    </span>
    <span class="collection-pill rounded-full text-xs font-medium">
      {post.collection}
    </span>
  </div>
  
  <a href={postUrl} class="group block">
    <h3 class="text-xl font-bold group-hover:text-orange-600 transition-colors mb-2">
      {post.data.title}
    </h3>
    <p class="text-gray-700 mb-4">{post.data.summary}</p>
  </a>
  
  {post.data.tags && post.data.tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {post.data.tags.map((tag) => (
        <span class="tag-pill flex items-center gap-1 text-xs px-2 py-1 rounded-full">
          <Tag size="3" />
          {tag}
        </span>
      ))}
    </div>
  )}
</article>
