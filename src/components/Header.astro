---
import HeaderLink from './HeaderLink.astro';
import ThemePills from './ThemePills.astro';
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:rounded focus:bg-blue focus:text-white">
  Skip to content
</a>

<header>
  <nav id="main-nav">
    <div class="w-1/2 md:w-32"></div>

    <div class="internal-links hidden md:flex gap-4">
      <HeaderLink href="/">HOME</HeaderLink>
      <HeaderLink href="/learn">LEARN</HeaderLink>
      <HeaderLink href="/journey">JOURNEY</HeaderLink>
      <HeaderLink href="/share">SHARE</HeaderLink>
      <HeaderLink href="/start-here">START HERE</HeaderLink>
      <HeaderLink href="/products">PRODUCTS</HeaderLink>
      <HeaderLink href="/about">ABOUT</HeaderLink>
    </div>

    <div class="social-links hidden md:flex md:gap-2 md:items-center">
      <ThemePills />
      <a href="https://techhub.social/@olddognewflex" target="_blank" rel="noopener noreferrer">
        <span class="sr-only">Follow Old Dog, New Flex on Mastodon</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
          ><path
            fill="currentColor"
            d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
          ></path></svg
        >
      </a>
      <a href="https://x.com/OldDogNewFlex" target="_blank" rel="noopener noreferrer">
        <span class="sr-only">Follow Old Dog, New Flex on X</span>
        <svg width="32" height="32" viewBox="0 0 1200 1227" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill="currentColor" d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"/>
        </svg>
      </a>
    </div>

    <!-- Hamburger toggle (mobile only) -->
    <button
      id="menu-toggle"
      class="md:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mauve"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="icon-open w-12 h-12" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg class="icon-close w-12 h-12" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Backdrop: dims page, click closes menu -->
    <div
      id="menu-backdrop"
      class="menu-backdrop fixed inset-0 z-40 md:hidden"
      style="background-color: rgba(14, 12, 27, 0.75);"
      aria-hidden="true"
    ></div>

    <!-- Slide-out menu panel -->
    <div
      id="mobile-menu"
      class="menu-panel fixed right-0 w-4/5 max-w-xs overflow-y-auto p-6 z-50 md:hidden"
      style="top: var(--header-height); height: calc(100vh - var(--header-height)); background-color: var(--color-mantle); border-left: 2px solid var(--color-mauve);"
      aria-label="Mobile navigation"
    >
      <nav>
        <HeaderLink href="/" class="mobile-nav-link">HOME</HeaderLink>
        <HeaderLink href="/learn" class="mobile-nav-link">LEARN</HeaderLink>
        <HeaderLink href="/journey" class="mobile-nav-link">JOURNEY</HeaderLink>
        <HeaderLink href="/share" class="mobile-nav-link">SHARE</HeaderLink>
        <HeaderLink href="/start-here" class="mobile-nav-link">START HERE</HeaderLink>
        <HeaderLink href="/products" class="mobile-nav-link">PRODUCTS</HeaderLink>
        <HeaderLink href="/about" class="mobile-nav-link">ABOUT</HeaderLink>
      </nav>
      <div class="mt-6 pt-6 border-t border-surface1">
        <ThemePills />
      </div>
      <div class="mt-6 flex gap-4">
        <a href="https://techhub.social/@olddognewflex" target="_blank" rel="noopener noreferrer" class="text-subtext0 hover:text-text transition-colors">
          <span class="sr-only">Follow on Mastodon</span>
          <svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24"><path fill="currentColor" d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"/></svg>
        </a>
        <a href="https://x.com/OldDogNewFlex" target="_blank" rel="noopener noreferrer" class="text-subtext0 hover:text-text transition-colors">
          <span class="sr-only">Follow on X</span>
          <svg width="24" height="24" viewBox="0 0 1200 1227" fill="none" aria-hidden="true"><path fill="currentColor" d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"/></svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0;
    height: var(--header-height);
    background: var(--color-base);
    border-bottom: 2px solid var(--color-mauve);
    display: flex;
    align-items: center;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  nav a {
    padding: 0.6em 0.3em 0.35em;
    line-height: 1.1;
    font-size: 1.05rem;
    color: var(--color-blue);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }

  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--color-teal);
  }

  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-surface1);
    font-size: 1.1rem;
  }

  @media (min-width: 768px) {
    header {
      position: sticky;
      top: 0;
      z-index: 50;
    }

    nav {
      padding-left: calc(10rem);
    }

    .internal-links {
      flex: 1 1 auto;
      justify-content: center;
      min-width: 0;
      gap: clamp(0.35rem, 1vw, 0.9rem);
    }

    .internal-links a {
      font-size: clamp(0.75rem, 1.15vw, 1.05rem);
    }
  }

  @media (min-width: 768px) and (max-width: 900px) {
    .internal-links {
      gap: 0.35rem;
    }

    .internal-links a {
      font-size: 0.7rem;
    }
  }

  .icon-close { display: none; }
  .icon-open  { display: block; }

  .menu-backdrop {
    visibility: hidden;
    opacity: 0;
    transition: opacity 200ms ease, visibility 200ms;
  }
  .menu-backdrop.is-open {
    visibility: visible;
    opacity: 1;
  }

  .menu-panel {
    visibility: hidden;
    transform: translateX(100%);
    transition: transform 200ms ease, visibility 200ms;
  }
  .menu-panel.is-open {
    visibility: visible;
    transform: translateX(0);
  }

  #menu-toggle[aria-expanded="true"] .icon-open  { display: none; }
  #menu-toggle[aria-expanded="true"] .icon-close { display: block; }
</style>

<script>
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement;
  const panel  = document.getElementById('mobile-menu')  as HTMLElement;
  const backdrop = document.getElementById('menu-backdrop') as HTMLElement;

  function openMenu() {
    panel.classList.add('is-open');
    backdrop.classList.add('is-open');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close navigation menu');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    panel.classList.remove('is-open');
    backdrop.classList.remove('is-open');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open navigation menu');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    toggle.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
  });

  backdrop.addEventListener('click', closeMenu);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      toggle.focus();
    }
  });
</script>
