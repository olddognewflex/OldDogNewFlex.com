---
import HeaderLink from './HeaderLink.astro';
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:rounded focus:bg-blue focus:text-base focus:text-white">
  Skip to content
</a>

<header>
	<nav>
		<div class="w-1/2 md:w-32"></div>
  
		<div class="internal-links hidden md:flex gap-4">
			<HeaderLink href="/">HOME</HeaderLink>
			<HeaderLink href="/learn">LEARN</HeaderLink>
			<HeaderLink href="/journey">JOURNEY</HeaderLink>
			<HeaderLink href="/share">SHARE</HeaderLink>
			<HeaderLink href="/start-here">START HERE</HeaderLink>
			<HeaderLink href="/products">PRODUCTS</HeaderLink>
			<HeaderLink href="/about">ABOUT</HeaderLink>
		</div>
		<div class="social-links hidden md:flex md:gap-2 md:items-center">
			<a href="https://techhub.social/@olddognewflex" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Follow Old Dog, New Flex on Mastodon</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
					></path></svg
				>
			</a>
			<a href="https://x.com/OldDogNewFlex" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Follow Old Dog, New Flex on X</span>
				<svg width="32" height="32" viewBox="0 0 1200 1227" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
					<path fill="currentColor" d="M714.163 519.284L1160.89 0H1055.03L667.137 450.887L357.328 0H0L468.492 681.821L0 1226.37H105.866L515.491 750.218L842.672 1226.37H1200L714.137 519.284H714.163ZM569.165 687.828L521.697 619.934L144.011 79.6944H306.615L611.412 515.685L658.88 583.579L1055.08 1150.3H892.476L569.165 687.854V687.828Z"/>
				</svg>
			</a>
		</div>
		<!-- Hamburger Icon -->
  	<button
    	class="md:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-mauve"
    	x-data="{ open: false }"
    	@click="open = !open"
    	aria-label="Toggle Menu"
  	>
    	<svg
      	x-show="!open"
      	xmlns="http://www.w3.org/2000/svg"
      	class="w-12 h-12"
      	fill="none"
      	viewBox="0 0 24 24"
      	stroke="currentColor"
      	aria-hidden="true"
    	>
      	<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        	d="M4 6h16M4 12h16M4 18h16" />
    	</svg>

    	<svg
      	x-show="open"
      	xmlns="http://www.w3.org/2000/svg"
      	class="w-12 h-12"
      	fill="none"
      	viewBox="0 0 24 24"
      	stroke="currentColor"
      	aria-hidden="true"
    	>
      	<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        	d="M6 18L18 6M6 6l12 12" />
    	</svg>

    	<!-- Slideout Menu -->
    	<div
      	x-show="open"
      	x-transition
      		class="fixed top-12 right-0 w-3/4 h-full text-white p-6 sm:hidden z-50"
      		style="background-color: var(--color-base); border-left: 2px solid var(--color-mauve);"
    	>
			<HeaderLink href="/" class="block w-9/10 py-2 border-b border-mantle">HOME</HeaderLink>
			<HeaderLink href="/learn" class="block w-9/10 py-2 border-b border-mantle">LEARN</HeaderLink>
			<HeaderLink href="/journey" class="block w-9/10 py-2 border-b border-mantle">JOURNEY</HeaderLink>
			<HeaderLink href="/share" class="block w-9/10 py-2 border-b border-mantle">SHARE</HeaderLink>
			<HeaderLink href="/about" class="block w-9/10 py-2 border-b border-mantle">ABOUT</HeaderLink>
		</div>
  	</button>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		height: var(--header-height);
		background: var(--color-base);
		border-bottom: 2px solid var(--color-mauve);
		display: flex;
		align-items: center;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
	}
	nav a {
		padding: 0.6em 0.3em 0.35em;
		line-height: 1.1;
		font-size: 1.05rem;
		color: var(--color-blue);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--color-teal);
	}

	@media (min-width: 768px) {
		header {
			position: sticky;
			top: 0;
			z-index: 50;
		}

		nav {
			padding-left: calc(10rem);
		}

		.internal-links {
			flex: 1 1 auto;
			justify-content: center;
			min-width: 0;
			gap: clamp(0.35rem, 1vw, 0.9rem);
		}

		.internal-links a {
			font-size: clamp(0.75rem, 1.15vw, 1.05rem);
		}

		@media (max-width: 900px) {
			.internal-links {
				gap: 0.35rem;
			}

			.internal-links a {
				font-size: 0.7rem;
			}
		}
	}
</style>
