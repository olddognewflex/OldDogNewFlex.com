---
import type { ImageProps } from '../../types';

const { 
  src, 
  alt, 
  width = 1200, 
  height = 630, 
  class: className = '',
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
}: ImageProps = Astro.props;
---

<img 
  src={src} 
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  decoding={decoding}
  class={className}
  fetchpriority={fetchpriority}
/> 