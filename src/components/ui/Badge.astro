---
import type { BadgeProps } from '../../types';

const { 
  variant = 'default', 
  size = 'md', 
  class: className = '' 
}: BadgeProps = Astro.props;

const baseClasses = 'inline-flex items-center gap-1 rounded-full font-medium';
const variantClasses = {
  default: 'bg-peach text-surface0',
  collection: 'bg-peach text-surface0',
  tag: 'bg-teal text-surface0',
  featured: 'bg-flamingo text-surface0'
};
const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-2 py-1 text-sm',
  lg: 'px-3 py-1.5 text-base'
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

<span class={classes}>
  <slot />
</span> 