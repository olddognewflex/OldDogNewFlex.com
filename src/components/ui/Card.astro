---
import type { CardProps } from '../../types';

const { 
  variant = 'default', 
  padding = 'md', 
  class: className = '' 
}: CardProps = Astro.props;

const baseClasses = 'rounded-lg transition-all duration-200';
const variantClasses = {
  default: 'bg-gradient-to-br from-mauve/75 to-mauve/50 border border-gray-200 hover:border-orange-300',
  featured: 'bg-gradient-to-br from-flamingo to-mauve border-2 border-orange-200',
  elevated: 'bg-gradient-to-br from-mauve/90 to-mauve/70 border border-gray-300 hover:border-orange-400 shadow-lg hover:shadow-xl'
};
const paddingClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const classes = `${baseClasses} ${variantClasses[variant]} ${paddingClasses[padding]} ${className}`;
---

<div class={classes}>
  <slot />
</div> 