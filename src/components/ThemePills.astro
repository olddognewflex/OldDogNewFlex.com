---
// ThemePills.astro
---

<style>
.theme-pill[aria-pressed="true"] {
  outline: 3px solid var(--yellow, #f9e2af);
  outline-offset: 2px;
}
.theme-pill {
  transition: outline 0.2s, box-shadow 0.2s;
  box-shadow: 0 1px 4px 0 rgba(0,0,0,0.08);
}
.theme-pill:focus {
  outline: 3px solid var(--mauve, #cba6f7);
  outline-offset: 2px;
}
</style>

<div id="theme-pills" class="flex gap-3 my-4">
  <button
    class="theme-pill latte border-2 border-transparent rounded-full w-5 h-5"
    data-theme="latte"
    title="Latte"
    aria-label="Latte"
    type="button"
  >🌻</button>
  <button
    class="theme-pill frappe border-2 border-transparent rounded-full w-5 h-5"
    data-theme="frappe"
    title="Frappé"
    aria-label="Frappé"
    type="button"
  >🪴</button>
  <button
    class="theme-pill macchiato border-2 border-transparent rounded-full w-5 h-5"
    data-theme="macchiato"
    title="Macchiato"
    aria-label="Macchiato"
    type="button"
  >🌺</button>
  <button
    class="theme-pill mocha border-2 border-transparent rounded-full w-5 h-5"
    data-theme="mocha"
    title="Mocha"
    aria-label="Mocha"
    type="button"
  >🌿</button>
</div>

