---
// src/pages/[category]/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { getAllPosts } from '../../lib/blog';

export async function getStaticPaths() {
  return [
    { params: { category: 'learn' } },
    { params: { category: 'share' } },
    { params: { category: 'journey' } }
  ];
}

const { category } = Astro.params;
const posts = await getAllPosts(category as 'learn' | 'share' | 'journey');

const categoryInfo = {
  learn: {
    title: 'Learn',
    heroImage: '/images/old-dog-teaching.webp',
    heroAlt: 'An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, standing at a podium',
    description: "Clear explanations of what's actually changing in tech — and what isn't — based on lived experience, not launch blogs.",
    icon: '🎓',
  },
  share: {
    title: 'Share',
    heroImage: '/images/old-dog-sharing.webp',
    heroAlt: 'An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, talking to a group of people showing them something on a tablet',
    description: "What I'm building, how I'm thinking about tools and systems, and why I make the tradeoffs I do.",
    icon: '🤝',
  },
  journey: {
    title: 'Journey',
    heroImage: '/images/old-dog-hiking.webp',
    heroAlt: 'An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, hiking up a mountain trail with a scenic view',
    description: 'Reflections on longevity, burnout, reinvention, and staying useful in an industry obsessed with newness.',
    icon: '🚀',
  },
};

const info = categoryInfo[category as keyof typeof categoryInfo];
---

<BaseLayout title={`${info.title} | Old Dog, New Flex`} description={info.description} heroImage={info.heroImage} heroAlt={info.heroAlt}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero overlay text (decorative tagline over hero image) -->
    <div class="hero-image" style="position: absolute; top: 140px; left: 30px; width: 40%;">
		  <h1 class="text-4xl font-extrabold text-left" style="text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.8);">
		    {info.title}
		  </h1>
    </div>

    <!-- Category Header -->
    <div class="text-center mb-12">
      <div class="text-6xl mb-4" aria-hidden="true">{info.icon}</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        {info.title}
      </h1>
      <p class="text-xl max-w-3xl mx-auto">
        {info.description}
      </p>
    </div>

    <!-- Posts Grid -->
    {posts.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-6xl mb-4" aria-hidden="true">📝</div>
        <h2 class="text-2xl font-bold mb-4">
          No posts here yet
        </h2>
        <p>
          Check back soon — new {info.title.toLowerCase()} posts are on the way.
        </p>
      </div>
    )}
  </div>
</BaseLayout>
