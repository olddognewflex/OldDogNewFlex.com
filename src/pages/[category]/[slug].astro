---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getReadingTime } from '../../lib/blog';
import { render } from 'astro:content';
import { ArrowLeft, Calendar, Clock } from '@lucide/astro';
import FormattedDate from '../../components/FormattedDate.astro';

const COLLECTION_LABELS: Record<string, string> = {
  learn: 'Learn',
  share: 'Share',
  journey: 'Journey',
};

export async function getStaticPaths() {
  const collections = await Promise.all([
    getCollection('learn'),
    getCollection('share'),
    getCollection('journey')
  ]);
  
  const posts = collections.flat();
  
  return posts.map((post) => ({
    params: { 
      category: post.collection, 
      slug: post.filePath?.split('/').pop()?.replace('.md', '') || ''
    },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<'learn' | 'share' | 'journey'>;
};

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = post.body ? getReadingTime(post.body) : 'Unknown';
const collectionLabel = COLLECTION_LABELS[post.collection] ?? post.collection;
---

<BlogPost
  title={post.data.title}
  summary={post.data.summary}
  publishedDate={post.data.publishedDate}
  updatedDate={post.data.updatedDate}
  heroImage={post.data.heroImage}
  tags={post.data.tags}
  post={post}
>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back Navigation -->
    <a 
      href={`/${post.collection}`}
      class="inline-flex items-center gap-1 text-text hover:text-blue mb-8"
    >
      <ArrowLeft size="16" aria-hidden="true" />
      Back to {collectionLabel}
    </a>

    <!-- Article Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-6 text-sm mb-6">
        <span class="flex items-center gap-2">
          <Calendar size="16" />
          <FormattedDate date={post.data.publishedDate} />
        </span>
        <span class="flex items-center gap-2">
          <Clock size="16" />
          {readingTime}
        </span>
        <span class="collection-pill text-text px-3 py-1 rounded-full text-sm font-medium">
          {collectionLabel}
        </span>
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="tag-pill text-text px-3 py-1 rounded-full text-sm">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Article Content -->
    <div class="prose prose-lg max-w-none prose-ul:list-disc prose-ol:list-decimal prose-li:my-1 prose-ul:pl-6 prose-ol:pl-6">
      <Content />
    </div>
  </article>
</BlogPost>
