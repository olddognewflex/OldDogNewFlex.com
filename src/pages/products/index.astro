---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductCard from "../../components/products/ProductCard.astro";
import Container from "../../components/ui/Container.astro";

const products = [
  {
    slug: "responsible-ai-adult",
    title: "Responsible AI Adult — Core Execution Pack",
    subtitle: "A production-safety framework for AI-assisted engineering.",
    status: "Available on Gumroad",
    badges: ["AI Safety", "Engineering Process", "Markdown-first"],
    description:
      "Six tool-agnostic agents that sanitize prompts, score risk, contain high-risk changes, verify intent drift, and execute safely (feature + refactor).",
    ctaLabel: "View product",
  },
];
---

<BaseLayout title="Products | Old Dog New Flex" description="Tools I actually use. No hype. Just scar tissue packaged nicely." heroImage="/images/old-dog-selling-show.webp" heroAlt="An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, holding a tablet pointing to the screen while standing on a stage with colorful lights and a tv studio atmosphere">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <div class="hero-image hidden md:block" style="position: absolute; top: 120px; right: 30px; width: 50%;">
      <p class="text-5xl font-extrabold text-right text-blue" style="text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.8);">
        Tools I Actually Use
      </p>
    </div>

    <section class="py-10">
      <Container>
        <div class="text-center">
          <h1 class="text-5xl font-bold text-blue mb-4">Products</h1>
          <p class="text-xl text-text max-w-3xl mx-auto">
            These are tools I actually use. They exist because I got tired of cleaning up the same messes over and over.
          </p>
        </div>
      </Container>
    </section>

    <section class="space-y-4">
      {products.map((p) => (
        <ProductCard product={p} />
      ))}
    </section>

    <div class="my-10 h-px bg-text/10" />

    <section class="rounded-2xl border border-surface1 bg-surface0 p-6">
      <h2 class="text-lg font-bold text-text">Want a heads-up when something drops?</h2>
      <p class="mt-2 text-sm text-subtext0">
        I don't spam. I don't do funnels. If you want a ping when a product goes live, this is the least annoying option.
      </p>

      <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href="mailto:raymond@olddognewflex.com?subject=Old%20Dog%20New%20Flex%20Product%20Updates&body=Hey%20Raymond%2C%20let%20me%20know%20when%20new%20products%20drop."
          class="inline-flex items-center justify-center rounded-xl border border-mauve/30 px-4 py-2 text-sm font-medium text-text hover:border-mauve/60 transition"
        >
          Email me for updates
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
