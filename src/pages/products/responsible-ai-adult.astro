---
import BaseLayout from "../../layouts/BaseLayout.astro";

const product = {
  title: "Responsible AI Adult — Core Execution Pack",
  description: "A production-safety framework for AI-assisted software engineering.",
  status: "Available", // e.g., "Available", "Coming Soon", "Discontinued"
  gumroadUrl: "https://olddognewflex.gumroad.com/l/responsible-ai-adult-core", // set later
};
---

<BaseLayout title={`${product.title} | Old Dog New Flex`} description={product.description}>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <nav class="mb-8">
      <a href="/products" class="text-sm text-subtext0 hover:text-text transition">
        ← Back to Products
      </a>
    </nav>

    <header class="mb-10">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl tracking-tight font-bold text-text">{product.title}</h1>
          <p class="mt-3 text-base text-subtext0 max-w-2xl">{product.description}</p>
        </div>

        <span class="inline-flex items-center rounded-full border border-surface2 bg-surface0 px-3 py-1 text-xs text-subtext0">
          {product.status}
        </span>
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        {product.status == "Available" && product.gumroadUrl ? (
          <a
            href={product.gumroadUrl}
            class="inline-flex items-center justify-center rounded-xl bg-text text-base px-5 py-2 text-sm font-semibold hover:opacity-90 transition"
          >
            Buy on Gumroad
          </a>
        ) : (
          <a
            href="mailto:raymond@olddognewflex.com?subject=Responsible%20AI%20Adult%20Launch%20Ping&body=Hey%20Raymond%2C%20ping%20me%20when%20Responsible%20AI%20Adult%20goes%20live."
            class="inline-flex items-center justify-center rounded-xl border border-mauve/30 px-5 py-2 text-sm font-semibold text-text hover:border-mauve/60 transition"
          >
            Get notified when it drops
          </a>
        )}

        <a
          href="/learn/ai-is-fast-production-is-fragile"
          class="inline-flex items-center justify-center rounded-xl border border-mauve/30 px-5 py-2 text-sm font-semibold text-text hover:border-mauve/60 transition"
        >
          Read: AI Is Fast, Production Is Fragile →
        </a>
      </div>
    </header>

    <article class="prose prose-invert max-w-none">
      <!-- Paste the one-page sales copy here as Markdown-ish HTML. -->
      <h2>You're already using AI. The question is whether it's using you.</h2>
      <p>
        AI can write code fast. It can also quietly expand scope, rewrite working systems, and introduce breaking changes
        with confidence. Most AI-related incidents don't start with bad intentions — they start with bad prompts.
      </p>

      <h2>What you get</h2>
      <ul>
        <li><strong>Agent 00</strong> — Sanitize and constrain raw prompts</li>
        <li><strong>Agent 01</strong> — Quantify blast radius and risk</li>
        <li><strong>Agent 02</strong> — Strict Mode prompt rewrite (phases, checkpoints, rollback)</li>
        <li><strong>Agent 03</strong> — Detect intent drift between prompts</li>
        <li><strong>Agent 04</strong> — Implement new features responsibly</li>
        <li><strong>Agent 05</strong> — Perform non-destructive refactors safely</li>
      </ul>

      <h2>How it works</h2>
      <ol>
        <li>Paste the Global Safety Preamble into your AI tool</li>
        <li>Run Agent 00</li>
        <li>Score with Agent 01</li>
        <li>If risk ≥ 6, run Agent 02</li>
        <li>Verify with Agent 03</li>
        <li>Execute with Agent 04 or 05</li>
      </ol>

      <h2>Bottom line</h2>
      <p>
        AI makes it easier to type. <strong>Responsible AI Adult makes it harder to screw up.</strong>
      </p>
    </article>
  </div>
</BaseLayout>
