---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import Container from '../components/ui/Container.astro';
import { getAllPosts, getFeaturedPosts } from '../lib/blog';

const [featuredPosts, recentPosts] = await Promise.all([
  getFeaturedPosts(),
  getAllPosts()
]);

const latestPosts = recentPosts.slice(0, 6);
---

<BaseLayout 
  title="Old Dog, New Flex | Home" 
  description="After nearly three decades of writing code, I've discovered the joy of diving headfirst into new and uncomfortable challenges. Join me on this ongoing journey—exploring fresh tech stacks, productivity experiments, and ventures beyond the keyboard."
  heroImage="/images/odnf-home-hero.webp" 
  heroAlt="An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, sitting confidently at a modern computer keyboard. The scene is colorful, vibrant, and filled with 80s-inspired nostalgia. The background is a cozy, cluttered room with toys and gadgets. The style is cinematic, realistic, and expressive, with dramatic lighting and detailed textures.">

  <div class="hero-image absolute left-10 w-8/10 md:w-2/3 lg:w-1/3 top-[140px] md:left-20">
		<h1 class="text-2xl font-extrabold text-left" style="text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.5);">
      Proving it's never too late to refactor your comfort zone
    </h1>
  </div>

  <!-- Hero Section -->
  <section class="py-10">
    <Container>
      <div class="text-center">
        <h1 class="text-5xl font-bold text-blue mb-4">Old Dog, New Flex</h1>
        <h2 class="text-3xl font-bold text-blue mb-4">Experience isn't a liability. It's leverage.</h2>
        <p class="text-xl text-text max-w-3xl mx-auto">
          I've spent nearly three decades building software through multiple hype cycles, architectural shifts, and
          "this changes everything" moments that... didn't.
        </p>
        <p class="mt-6 text-2xl">
          This site is where I document how I am <b>learning</b>, <b>building</b>, and <b>shipping</b> <i>now</i> - in an era of AI,
          automation, and accelerating noise - with context, restraint, and responsibility.
        </p>
				<p class="mt-6 text-2xl font-bold emphasized-point">
					No hype.<br />
          No predictions.<br />
          Just durable thinking from someone who's seen a few things break.
        </p>    
      </div>
    </Container>
  </section>

  <section class="py-10">
    <Container>
      <div class="text-center">
        <h2 class="text-3xl font-bold mb-4">What You'll Find Here</h2>
        <div class="flex flex-col md:flex-row gap-y-8 md:gap-y-0 md:gap-x-8 text-left">
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <h3 class="text-xl font-bold mb-2">Learn</h3>
            <p class="text-xl">
              Clear explanations of what's actually changing in tech - and what isn't - based on lived
							experience, not launch blogs.
            </p>
          </div>
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <h3 class="text-xl font-bold mb-2">Share</h3>
            <p class="text-xl">
              What I'm building, how I'm thinking about tools and systems, and why I make the tradeoffs I do.
            </p>
          </div>
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <h3 class="text-xl font-bold mb-2">Journey</h3>
            <p class="text-xl">
              Reflections on longevity, burnout, reinvention, and staying useful in an industry obsessed with newness.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="py-10">
    <Container>
      <div class="text-center">
        <h2 class="text-3xl font-bold mb-4">What This Site Is (and Isn't)</h2>
        <div class="flex flex-col md:flex-row gap-y-8 md:gap-y-0 md:gap-x-8 text-center">
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <p class="text-xl">
              This isn't a news site.<br />
              It isn't a trend report.
              It isn't a motivational feed.
            </p>
            <p class="text-xl">
              It's a long-game project for people who care about <strong>durability over novelty</strong>.
            </p>
            <p class="text-xl">
              If that resonates, you're in the right place.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="py-12">
      <Container>
        <h2 class="text-3xl font-bold mb-8">Featured</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {featuredPosts.map((post) => (
            <BlogCard post={post} featured />
          ))}
        </div>
      </Container>
    </section>
  )}

  <!-- Latest Posts -->
  <section class="py-12">
    <Container>
      <h2 class="text-3xl font-bold mb-8">Latest</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </Container>
  </section>

  <!-- Newsletter Signup -->
  <section class="py-16">
    <Container size="md">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-blue mb-4">Join the Learning Journey</h2>
        <p class="text-text mb-8">Get updates on new posts and learning adventures. No spam, just growth.</p>
        <div class="bg-overlay2 p-6 rounded-lg">
          <p class="text-text">Newsletter signup coming soon!</p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
