---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import { getAllPosts, getFeaturedPosts } from '../lib/blog';

const [featuredPosts, recentPosts] = await Promise.all([
  getFeaturedPosts(),
  getAllPosts()
]);

const latestPosts = recentPosts.slice(0, 6);
---

<BaseLayout 
  title="Old Dog, New Flex | Home" 
  heroTagline="Proving it's never too late to refactor your comfort zone" 
  heroImage="/images/odnf-home-hero.png" 
  heroAlt="An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, sitting confidently at a modern computer keyboard. The scene is colorful, vibrant, and filled with 80s-inspired nostalgia. The background is a cozy, cluttered room with toys and gadgets. The style is cinematic, realistic, and expressive, with dramatic lighting and detailed textures.">
  <!-- Hero Section -->
  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-5xl font-bold text-blue mb-4">Welcome to Old Dog New Flex</h1>
      <p class="text-xl text-text max-w-3xl mx-auto">
        After nearly three decades of writing code, chasing semicolons, mentoring developers, and surviving endless
        tech trends, I've discovered the joy of diving headfirst into new and uncomfortable challenges. At Old Dog New 
        Flex, you'll join me on this ongoing journey—exploring fresh tech stacks, productivity experiments, and even
        ventures beyond the keyboard.
      </p>
      <p class="mt-6 text-2xl font-bold emphasized-point">
        I'm here to show you that curiosity has no expiration date and comfort zones are overrated.
      </p>
    </div>
  </section>

  <section class="py-10 bg-overlay1">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">What You Will Find Here</h2>
      <div class="flex flex-col md:flex-row gap-y-8 md:gap-y-0 md:gap-x-8 text-left">
        <div class="flex-1 bg-surface0 p-6 rounded-lg shadow-lg">
          <h4 class="text-xl font-bold mb-2">Tech Adventures:</h4>
          <p class="text-xl text-text">
            Embracing modern stacks (Astro, GraphQL, TypeScript) with honest experiences and practical tips.
          </p>
        </div>
        <div class="flex-1 bg-surface2 p-6 rounded-lg shadow-lg">
          <h4 class="text-xl font-bold mb-2">Life Hacks & Productivity:</h4>
          <p class="text-xl text-text">
            Strategies and tools to help tech veterans and newcomers alike thrive at the keyboard.
          </p>
        </div>
        <div class="flex-1 bg-surface0 p-6 rounded-lg shadow-lg">
          <h4 class="text-xl font-bold mb-2">Real Talk & Reflections:</h4>
          <p class="text-xl text-text">
            Candid takes on developer life, trends, and the occasional nostalgic rant.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h2 class="text-3xl font-bold text-blue mb-8">Featured</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {featuredPosts.map((post) => (
          <BlogCard post={post} featured />
        ))}
      </div>
    </section>
  )}

  <!-- Latest Posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-3xl font-bold text-blue mb-8">Latest</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.map((post) => (
        <BlogCard post={post} />
      ))}
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-blue mb-4">Join the Learning Journey</h2>
      <p class="text-text mb-8">Get updates on new posts and learning adventures. No spam, just growth.</p>
      <div class="bg-overlay2 p-6 rounded-lg">
        <p class="text-text">Newsletter signup coming soon!</p>
      </div>
    </div>
  </section>
</BaseLayout>
