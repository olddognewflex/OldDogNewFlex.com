---
// src/pages/[category]/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import { getFeaturedPosts, getAllPosts } from '../lib/blog';

const [featuredPosts, recentPosts] = await Promise.all([
  getFeaturedPosts(),
  getAllPosts()
]);

const latestPosts = recentPosts.slice(0, 6);
---

<BaseLayout title="Old Dog, New Flex Blog" description="Explore my journey of learning, sharing, and growing in the tech world.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Category Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        Old Dog, New Flex Blog
      </h1>
    </header>

    <section class="py-10">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4">Explore my journey of learning, sharing, and growing in the tech world.</h2>
        <div class="flex flex-col md:flex-row gap-y-8 md:gap-y-0 md:gap-x-8 text-left">
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <h4 class="text-xl font-bold mb-2"><a href="/learn">Learn</a></h4>
            <p class="text-xl">
              Embracing modern stacks (Astro, GraphQL, TypeScript) with honest experiences and practical tips.
            </p>
          </div>
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <h4 class="text-xl font-bold mb-2"><a href="/share">Share</a></h4>
            <p class="text-xl">
              Knowledge sharing, Mentorship, Strategies and tools to help tech veterans and newcomers alike thrive at the keyboard.
            </p>
          </div>
          <div class="flex-1 p-6 rounded-lg shadow-lg">
            <h4 class="text-xl font-bold mb-2"><a href="/journey">Journey</a></h4>
            <p class="text-xl">
              Candid takes on developer life, trends, and the occasional nostalgic rant.
            </p>
          </div>
        </div>
      </div>
    </section>
    
    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-3xl font-bold text-blue mb-8">Featured</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredPosts.map((post) => (
            <BlogCard post={post} featured />
          ))}
        </div>
      </section>
    )}

    <!-- Latest Posts -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h2 class="text-3xl font-bold text-blue mb-8">Latest</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
