---
// src/pages/blog.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import { getFeaturedPosts, getAllPosts } from '../lib/blog';

const [featuredPosts, recentPosts] = await Promise.all([
  getFeaturedPosts(),
  getAllPosts()
]);

const latestPosts = recentPosts.slice(0, 6);
---

<BaseLayout title="The Blog | Old Dog, New Flex" description="Explore my journey of learning, sharing, and growing in the tech world.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <header class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">The Blog</h1>
      <p class="text-xl max-w-2xl mx-auto">
        Three ways of thinking. All of them intentional.
      </p>
    </header>

    <section class="py-10">
      <div class="flex flex-col md:flex-row gap-y-8 md:gap-y-0 md:gap-x-8 text-left">
        <div class="flex-1 p-6 rounded-lg shadow-lg">
          <h2 class="text-xl font-bold mb-2"><a href="/learn">Learn</a></h2>
          <p class="text-xl">
            Clear explanations of what's actually changing in tech — and what isn't — based on lived experience, not launch blogs.
          </p>
        </div>
        <div class="flex-1 p-6 rounded-lg shadow-lg">
          <h2 class="text-xl font-bold mb-2"><a href="/share">Share</a></h2>
          <p class="text-xl">
            What I'm building, how I'm thinking about tools and systems, and why I make the tradeoffs I do.
          </p>
        </div>
        <div class="flex-1 p-6 rounded-lg shadow-lg">
          <h2 class="text-xl font-bold mb-2"><a href="/journey">Journey</a></h2>
          <p class="text-xl">
            Reflections on longevity, burnout, reinvention, and staying useful in an industry obsessed with newness.
          </p>
        </div>
      </div>
    </section>
    
    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <h2 class="text-3xl font-bold text-blue mb-8">Featured</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {featuredPosts.map((post) => (
            <BlogCard post={post} featured />
          ))}
        </div>
      </section>
    )}

    <!-- Latest Posts -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h2 class="text-3xl font-bold text-blue mb-8">Latest</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
