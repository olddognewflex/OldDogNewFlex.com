---
import BlogCard from '../components/blog/BlogCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts, getFeaturedPosts } from '../lib/blog';

const [featuredPosts, recentPosts] = await Promise.all([
  getFeaturedPosts(),
  getAllPosts()
]);

const latestPosts = recentPosts.slice(0, 6);
---

<BaseLayout
	title="About Me"
	heroImage="/images/odnf-about-hero.webp"
  heroAlt="An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones, sitting confidently at a modern computer keyboard. The scene is colorful, vibrant, and filled with 80s-inspired nostalgia. The background is a cozy, cluttered room with toys and gadgets. The style is cinematic, realistic, and expressive, with dramatic lighting and detailed textures."
>
  <div class="hero-image" style="position: absolute; top: 120px; right: 30px; width: 50%;">
		<h1 class="text-5xl font-extrabold text-right" style="text-shadow: 4px 4px 8px rgba(0, 0, 0, 0.8);">
			The journey of a thousand lines of code begins with a single semicolon
		</h1>
  </div>

  <section class="py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h1>About this Old Dog</h1>
			<p>
				Hey there—I’m Raymond, a seasoned software engineer who’s spent nearly 30 years wrestling with code, mentoring devs,
				and building things that (mostly) work. This blog is my public journey out of the comfort zone, exploring new tech, 
				productivity hacks, and maybe even a few life lessons learned the hard way.
			</p>
			
			<p>
				And yes, that old guy with the neon glasses and retro-futuristic vibe plastered all over the site? He’s my 
				aspirational alter ego—the laid-back, fearless learner I’m steadily becoming. We’ll see how that turns out.
			</p>

			<p>
				When I’m not chasing semicolons or debugging life, you’ll usually find me with my wife, seven kids, and six dogs 
				enjoying life in beautiful Tennessee, or scheming about what to learn next.
			</p>
			<p>
				Check out what I'm flexing on lately
			</p>
			
    </div>
  </section>
  <!-- Latest Posts -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-3xl font-bold text-blue mb-8">Latest</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {latestPosts.map((post) => (
        <BlogCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
