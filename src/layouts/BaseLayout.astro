---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';

import "../styles/global.css";

// src/layouts/BaseLayout.astro
export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  heroImage?: string;
  heroAlt?: string;
  heroTaglineElement?: any;
  article?: boolean;
  publishedDate?: Date;
  updatedDate?: Date;
  author?: string;
  tags?: string[];
}

const { 
	title,
	description = "Proving it's never too late to refactor your comfort zone",
	canonicalURL,
	heroImage, 
	heroTaglineElement,
	heroAlt = "An elderly man with a long white beard and flowing hair, wearing bright, retro-futuristic clothes including an orange and pink jacket, neon sunglasses, and large headphones",
	article = false,
	publishedDate,
	updatedDate,
	author,
	tags = []
} = Astro.props;

const headerHeight = '100px'; 
---

<!DOCTYPE html>
<html data-theme="mocha" lang="en">
	<head>
		<BaseHead 
			title={title} 
			description={description} 
			canonicalURL={canonicalURL}
			article={article}
			publishedDate={publishedDate}
			updatedDate={updatedDate}
			author={author}
			tags={tags}
		/>
		<style>
			main {
				width: calc(100%);
				max-width: 100%;
				margin: auto;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: var(--color-text);
			}
			.tagline {
				color: var(--color-blue);
			}
		</style>
	</head>
  <body>
		<Header />
		{heroImage && 
		<PageHero heroImage={heroImage} heroAlt={heroAlt} />
		}
    <main class="flex-1 justify-center">
      <slot />
    </main>

    <footer class="bg-base text-blue py-12">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
					<img src='/images/old-dog-new-flex-logo.svg' alt="Old Dog, New Flex Logo" class="mx-auto"/>
          <p class="tagline text-lg mb-4">Proving it's never too late to refactor your comfort zone</p>
          <p class="text-text text-sm">© 2024 Old Dog, New Flex. Built with Astro and TypeScript.</p>
        </div>
      </div>
    </footer>
		<img src='/images/old-dog-new-flex-logo.svg' alt="Old Dog, New Flex Logo" class="absolute top-5 left-5 md:w-65"/>
		
		<!-- Alpine.js -->
		<script>
			import Alpine from 'alpinejs';
			window.Alpine = Alpine;
			Alpine.start();
		</script>
		</body>
</html>

