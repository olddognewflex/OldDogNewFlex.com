---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

type Props = CollectionEntry<'learn'|'share'|'journey'>['data'] & {
	post: CollectionEntry<'learn'|'share'|'journey'>;
};

const { title, summary, publishedDate, updatedDate, heroImage, tags = [], post } = Astro.props;
const author = 'Old Dog New Flex';
---

<BaseLayout 
	title={`${title} | Old Dog, New Flex`}
	description={summary}
	article={true}
	publishedDate={publishedDate}
	updatedDate={updatedDate}
	author={author}
	tags={tags}
	heroImage={heroImage}
	heroAlt={title}
>
	<slot />
</BaseLayout>
